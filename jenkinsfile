pipeline {
    agent any 


    environment {
        COMPOSE_FILE = 'docker-compose.yml'
        SONAR_HOST = 'http://sonarqube:9000'
        SONAR_TOKEN = credentials('sonar-token')
    }

    options {
        timestamps()
    }

    stages {

        // ✅ 1. Backend tests
        stage('Backend Tests') {
            steps {
                sh '''
                cd todo-backend
                chmod +x mvnw
                ./mvnw clean verify
                '''
            }
        }

        // 🔥 2. Sonar Backend
        stage('Sonar Backend Analysis') {
            steps {
                sh '''
                cd todo-backend
                ./mvnw sonar:sonar \
                  -Dsonar.projectKey=todo-backend \
                  -Dsonar.host.url=$SONAR_HOST \
                  -Dsonar.login=$SONAR_TOKEN
                '''
            }
        }


        stage('Debug Frontend Path') {
    steps {
        sh '''
        ls -la taskFlow
        ls -la taskFlow/*
        '''
    }
}

        // 🧪 3. Frontend Tests (Angular)
        stage('Frontend Tests') {
    steps {
        sh '''
        docker run --rm \
          -v "$WORKSPACE/taskFlow:/app" \
          -w /app \
          node:18 \
          sh -c "
            ls -la &&
            npm install &&
            npm run test -- --watch=false --browsers=ChromeHeadless --code-coverage
          "
        '''
    }
}

        // 🔥 4. Sonar Frontend
        stage('Sonar Frontend Analysis') {
            steps {
                sh '''
                cd taskFlow

                sonar-scanner \
                  -Dsonar.projectKey=todo-frontend \
                  -Dsonar.sources=src \
                  -Dsonar.tests=src \
                  -Dsonar.test.inclusions=**/*.spec.ts \
                  -Dsonar.exclusions=**/node_modules/** \
                  -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                  -Dsonar.host.url=$SONAR_HOST \
                  -Dsonar.login=$SONAR_TOKEN
                '''
            }
        }

        // 🐳 5. Build containers AFTER quality check
        stage('Build Containers') {
            steps {
                sh 'docker compose -f $COMPOSE_FILE build'
            }
        }

        // 🚀 6. Start services
        stage('Start Services') {
            steps {
                sh 'docker compose -f $COMPOSE_FILE up -d'
            }
        }

        // 📊 7. Show containers
        stage('Show Running Containers') {
            steps {
                sh 'docker compose ps'
            }
        }
    }

    post {
        always {
            sh '''
            echo "Application logs:"
            docker compose logs || true
            '''
        }

        success {
            echo " Pipeline completed successfully!"
        }

        failure {
            echo " Pipeline failed. Check logs above."
        }
    }
}