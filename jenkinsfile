pipeline {
    agent any 

    environment {
        COMPOSE_FILE = 'docker-compose.yml'
        SONAR_HOST = 'http://sonarqube:9000'
        SONAR_TOKEN = credentials('sonar-token')

        DOCKER_IMAGE_BACK = 'todo-backend'
        DOCKER_IMAGE_FRONT = 'taskflow'
        VERSION = "${BUILD_NUMBER}"   // simple versioning
    }

    options {
        timestamps()
    }

    stages {

        //  TESTS IN PARALLEL
        stage('Tests') {
            parallel {

                stage('Backend Tests') {
                    steps {
                        sh '''
                        cd todo-backend
                        chmod +x mvnw
                        ./mvnw clean verify
                        '''
                    }
                }

                stage('Frontend Tests') {
                    environment {
                        CHROME_BIN = '/usr/bin/chromium'
                    }
                    steps {
                        sh '''
                        cd taskFlow
                        npm ci
                        npm run test -- --watch=false --code-coverage
                        '''
                    }
                }
            }
        }

        // SONAR ANALYSIS IN PARALLEL
        stage('Sonar Analysis') {
            parallel {

                stage('Backend Sonar') {
                    steps {
                        sh '''
                        cd todo-backend
                        ./mvnw sonar:sonar \
                          -Dsonar.projectKey=todo-backend \
                          -Dsonar.host.url=$SONAR_HOST \
                          -Dsonar.login=$SONAR_TOKEN
                        '''
                    }
                }

                stage('Frontend Sonar') {
                    steps {
                        sh '''
                        cd taskFlow
                        npx sonar-scanner \
                          -Dsonar.projectKey=todo-frontend \
                          -Dsonar.sources=src \
                          -Dsonar.host.url=$SONAR_HOST \
                          -Dsonar.login=$SONAR_TOKEN \
                          -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info
                        '''
                    }
                }
            }
        }

        //  QUALITY GATE (IMPORTANT)
        stage('Quality Gate') {
            steps {
                timeout(time: 2, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        // BUILD DOCKER IMAGES
        stage('Build Docker Images') {
            steps {
                sh '''
                docker compose -f $COMPOSE_FILE build

                # Tag with version
                docker tag backend:1.0 $DOCKER_IMAGE_BACK:$VERSION
                docker tag taskflow:1.0 $DOCKER_IMAGE_FRONT:$VERSION
                '''
            }
        }

        //  PUSH TO DOCKER HUB
        stage('Push Images') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-hub',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {

                    sh '''
                    echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin

                    docker tag $DOCKER_IMAGE_BACK:$VERSION $DOCKER_USER/$DOCKER_IMAGE_BACK:latest
                    docker tag $DOCKER_IMAGE_FRONT:$VERSION $DOCKER_USER/$DOCKER_IMAGE_FRONT:latest

                    docker push $DOCKER_USER/$DOCKER_IMAGE_BACK:latest
                    docker push $DOCKER_USER/$DOCKER_IMAGE_FRONT:latest

                    docker logout
                    '''
                }
            }
        }

        //  DEPLOY TO KUBERNETES
        stage('Deploy') {
            steps {
                sh '''
                echo "Deploying to Kubernetes..."

                kubectl apply -f k8s/namespace.yml
                kubectl apply -f k8s/ -n task-flow

                # Wait for rollout
                kubectl rollout status deployment/backend -n task-flow
                kubectl rollout status deployment/frontend -n task-flow

                echo "Deployment successful"
                '''
            }
        }
    }

    post {
        always {
            sh 'docker compose logs || true'
        }

        success {
            echo " Pipeline SUCCESS"
        }

        failure {
            echo " Pipeline FAILED"
        }
    }
}
