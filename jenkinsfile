pipeline {
    agent any 

    environment {
        COMPOSE_FILE = 'docker-compose.yml'
    }

    options {
        timestamps()
    }

    stages {

        stage('Build Containers'){
            steps{
                sh 'docker compose -f $COMPOSE_FILE build'
            }
        }

        stage('Start Services'){
            steps{
                sh 'docker compose -f $COMPOSE_FILE up -d'
            }
        }

        stage('Wait for Backend') {
            steps {
                sh '''
                echo "Waiting for backend (port 8090)..."

                for i in $(seq 1 40); do
                  echo "Attempt $i/40..."

                  # Check if port 8090 is open (no curl, no auth needed)
                  if timeout 1 bash -c "</dev/tcp/localhost/8090" 2>/dev/null; then
                    echo "Backend port is open "
                    exit 0
                  fi

                  sleep 3
                done

                echo "Backend not reachable "
                exit 1
                '''
            }
        }

        stage('Test Backend (Port Check)') {
            steps {
                sh '''
                echo "Final backend check..."

                if timeout 1 bash -c "</dev/tcp/localhost/8090" 2>/dev/null; then
                  echo "Backend is reachable "
                else
                  echo "Backend test failed "
                  exit 1
                fi
                '''
            }
        }

        stage('Test Frontend') {
            steps {
                sh '''
                echo "Testing frontend..."

                curl --fail http://localhost:4200 || exit 1

                echo "Frontend is working "
                '''
            }
        }
    }

    post {
        always {
            sh 'docker compose logs || true'
            sh 'docker compose -f $COMPOSE_FILE down'
        }
    }
}
